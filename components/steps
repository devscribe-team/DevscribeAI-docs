  -H 'Authorization: Bearer YOUR_API_KEY'`}
</CodeSnippet>

<CodeSnippet language="javascript" title="JavaScript">
{`const response = await fetch('https://api.example.com/users', {
  headers: { Authorization: \`Bearer \${apiKey}\` }
})`}
